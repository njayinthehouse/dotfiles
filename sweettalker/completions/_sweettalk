#compdef sweettalk
# Completion for `sweettalk` — the sweettalker terminal-look selector. Installed
# to ~/.local/share/zsh/site-functions/_sweettalk by sweettalker/install.sh.
#
# The look/prompt/font/foreground/background/palette/guess/learned aliases
# (defined in ~/.zshrc as `sweettalk <x>`) inherit this completion for free:
# zsh expands an alias before completing, so `look <TAB>` becomes
# `sweettalk look <TAB>` and lands here.

# `look` subcommands (the whole-look scope).
_sweettalk_look() {
  local curcontext="$curcontext" state line
  _arguments -C '1: :->sub' '*::arg:->subarg'
  case $state in
    sub)
      local -a subs
      subs=(
        'roll:roll a fresh look'
        'auto:show/set per-session autoroll'
        'duel:rate current vs an informative opponent'
        'refine:rate current vs a small local tweak'
        'explore:show/set the exploration rate'
        'help:show help'
      )
      _describe -t look-subcommands 'look subcommand' subs
      ;;
    subarg)
      case $line[1] in
        roll)    _values 'mode' explore exploit ;;
        auto)    _values 'autoroll' on off ;;
        explore) _values 'rate' 'auto[let the engine pick]' ;;  # or a 0..1 float
      esac
      ;;
  esac
}

# A single lever (prompt/font/foreground/background/palette).
_sweettalk_lever() {
  local curcontext="$curcontext" state line
  _arguments -C '1: :->sub' '*::arg:->subarg'
  case $state in
    sub)
      local -a subs
      subs=(
        'roll:roll this lever'
        'duel:rate current vs an informative opponent on this lever'
        'refine:rate current vs a small tweak of this lever'
        'help:show help'
      )
      _describe -t lever-subcommands 'lever subcommand' subs
      ;;
    subarg)
      case $line[1] in
        roll) _values 'mode' explore exploit ;;
      esac
      ;;
  esac
}

_sweettalk() {
  local curcontext="$curcontext" state line
  local -a cmds
  cmds=(
    'status:show the current look'
    'look:show / roll / duel the whole look'
    'prompt:the prompt lever'
    'font:the font lever'
    'foreground:the foreground colour lever'
    'background:the background colour lever'
    'palette:the ANSI palette lever'
    'guess:predicted rating of the current look'
    'learned:what the model has learned about your taste'
    'session:roll-once-per-session hook (startx)'
    'startup:apply-current-look hook (shell start)'
  )

  _arguments -C \
    '1: :->cmd' \
    '*::arg:->args'

  case $state in
    cmd)
      _describe -t commands 'sweettalk command' cmds
      ;;
    args)
      case $line[1] in
        look)                                            _sweettalk_look ;;
        prompt|font|foreground|background|palette)  _sweettalk_lever ;;
      esac
      ;;
  esac
}

_sweettalk "$@"
